F90INCLUDES = -I./$(CAMBDIR)/
COMFLAGS = -DINDEX -DVarPM -DNNX=4180 -DNNY=4180 -DNNZ=4180 -DLOCAL_NNZ=128 -DNPROCS=824 

FDFLAGS =  -DINCLUDE_TREE_FORCE 

CDFLAGS = -DNMEG=3000L -DCORRELATION_FUNCTION \
		-DINCLUDE_TREE_FORCE \
        -D_LARGE_FILES -DSAVESLICE \
        -DOBSERVATION_MODE  -DPMSEEDFORCE 


FFLAGS = $(FDFLAGS) $(OPT) $(COMFLAGS)  
CFLAGS = $(OPT) $(CDFLAGS)  $(COMFLAGS) 
LDFLAGS = $(OPT) 
CAMBLIBS = -L./$(CAMBDIR) -lcamb
