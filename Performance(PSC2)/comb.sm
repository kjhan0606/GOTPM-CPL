lines 17 17
read { x 1 y 2 n 3}
set n = n**3
set co = n/y/x
set lx = lg(x)
set ly = (co)
#points lx ly
#connect lx ly

ltype 3
ptype 6 3
lines 18 19
read { x 1 y 2 n 3}
